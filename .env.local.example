# Copiar a .env.local y llenar con las credenciales del proyecto de Supabase
# (Project Settings > API en el dashboard). No commitear .env.local.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key: bypasa RLS. Solo se usa en el servidor (scripts, Route
# Handlers). Nunca exponerla al cliente ni prefijarla con NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=
